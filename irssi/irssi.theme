abstracts = {
  timestamp = "%K$*";
  msgnick = "%n$0$1-%n: ";
  pubnick = "%R$*%n";
  action_core = "%M%_ * $*%n";
  sb_background = "%N";
  prompt = "$* > ";
};

formats = {
  "fe-common/core" = {
    join = "{channick $0} %_%G>>";
    part = "{channick $0} %_%R<<";
    quit = "{channick $0} %_%R<<< %_%K{reason $2}";
    quit_once = "{channick $0} %_%R<<< %_%K{reason $2}";
  };
};
